#include <WiFi.h>
#include "esp_camera.h"
#include <HTTPClient.h>
#include "mbedtls/md.h"
#include "soc/soc.h"
#include "soc/rtc_cntl_reg.h" 


const char* ssid = "**";
const char* password = "**";
String serverUrl = "**";
const char* secretKey = "**";


#define LED_PIN 4      
#define BUTTON_PIN 2   
#define TRIG_PIN 13    
#define ECHO_PIN 12    


const int MIN_DISTANCE = 30; 
const int MAX_DISTANCE = 80; 


unsigned long lastMeasureTime = 0;
const long measureInterval = 2000; 


#define PWDN_GPIO_NUM     32
#define RESET_GPIO_NUM    -1
#define XCLK_GPIO_NUM      0
#define SIOD_GPIO_NUM     26
#define SIOC_GPIO_NUM     27
#define Y9_GPIO_NUM       35
#define Y8_GPIO_NUM       34
#define Y7_GPIO_NUM       39
#define Y6_GPIO_NUM       36
#define Y5_GPIO_NUM       21
#define Y4_GPIO_NUM       19
#define Y3_GPIO_NUM       18
#define Y2_GPIO_NUM        5
#define VSYNC_GPIO_NUM    25
#define HREF_GPIO_NUM     23
#define PCLK_GPIO_NUM     22

long readDistanceFiltered() {
  long samples[5];
  int validSamples = 0;
  
  for(int i = 0; i < 5; i++) {
    digitalWrite(TRIG_PIN, LOW);
    delayMicroseconds(2);
    digitalWrite(TRIG_PIN, HIGH);
    delayMicroseconds(10);
    digitalWrite(TRIG_PIN, LOW);
    
  
    long duration = pulseIn(ECHO_PIN, HIGH, 30000); 
    long d = (duration == 0) ? 999 : (duration * 0.034 / 2);
    
    
    if (d > 2 && d < 400) {
      samples[validSamples] = d;
      validSamples++;
    }
    delay(30); 
  }

  if (validSamples < 3) return 999; 

  
  for(int i = 0; i < validSamples - 1; i++) {
    for(int j = i + 1; j < validSamples; j++) {
      if(samples[i] > samples[j]) {
        long temp = samples[i];
        samples[i] = samples[j];
        samples[j] = temp;
      }
    }
  }

  
  long sum = 0;
  for(int i = 1; i < validSamples - 1; i++) {
    sum += samples[i];
  }
  return sum / (validSamples - 2);
}


String calculateHMAC(uint8_t* data, size_t len) {
  byte hmacResult[32];
  mbedtls_md_context_t ctx;
  mbedtls_md_init(&ctx);
  mbedtls_md_setup(&ctx, mbedtls_md_info_from_type(MBEDTLS_MD_SHA256), 1);
  mbedtls_md_hmac_starts(&ctx, (const unsigned char *) secretKey, strlen(secretKey));
  mbedtls_md_hmac_update(&ctx, (const unsigned char *) data, len);
  mbedtls_md_hmac_finish(&ctx, hmacResult);
  mbedtls_md_free(&ctx);

  String hashStr = "";
  for(int i=0; i<32; i++){
    if(hmacResult[i] < 16) hashStr += "0";
    hashStr += String(hmacResult[i], HEX);
  }
  return hashStr;
}

void setup() {
  WRITE_PERI_REG(RTC_CNTL_BROWN_OUT_REG, 0); 
  Serial.begin(115200);

  pinMode(TRIG_PIN, OUTPUT);
  pinMode(ECHO_PIN, INPUT);
  pinMode(LED_PIN, OUTPUT);           
  pinMode(BUTTON_PIN, INPUT_PULLUP); 

  digitalWrite(LED_PIN, LOW); 

  Serial.print("WiFi Baglaniyor...");
  WiFi.begin(ssid, password);
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }
  Serial.println("\nWiFi Baglandi! IP: " + WiFi.localIP().toString());

  camera_config_t config;
  config.ledc_channel = LEDC_CHANNEL_0;
  config.ledc_timer = LEDC_TIMER_0;
  config.pin_d0 = Y2_GPIO_NUM;
  config.pin_d1 = Y3_GPIO_NUM;
  config.pin_d2 = Y4_GPIO_NUM;
  config.pin_d3 = Y5_GPIO_NUM;
  config.pin_d4 = Y6_GPIO_NUM;
  config.pin_d5 = Y7_GPIO_NUM;
  config.pin_d6 = Y8_GPIO_NUM;
  config.pin_d7 = Y9_GPIO_NUM;
  config.pin_xclk = XCLK_GPIO_NUM;
  config.pin_pclk = PCLK_GPIO_NUM;
  config.pin_vsync = VSYNC_GPIO_NUM;
  config.pin_href = HREF_GPIO_NUM;
  config.pin_sscb_sda = SIOD_GPIO_NUM;
  config.pin_sscb_scl = SIOC_GPIO_NUM;
  config.pin_pwdn = PWDN_GPIO_NUM;
  config.pin_reset = RESET_GPIO_NUM;
  config.xclk_freq_hz = 20000000;
  config.pixel_format = PIXFORMAT_JPEG;
  
  if(psramFound()){
    config.frame_size = FRAMESIZE_UXGA;
    config.jpeg_quality = 10;
    config.fb_count = 2;
  } else {
    config.frame_size = FRAMESIZE_SVGA;
    config.jpeg_quality = 12;
    config.fb_count = 1;
  }

  if (esp_camera_init(&config) != ESP_OK) {
    Serial.println("Kamera Hatasi!");
    return;
  }
  Serial.println("Sistem Hazir!");
}

void loop() {
  unsigned long currentMillis = millis();


  if (currentMillis - lastMeasureTime >= measureInterval) {
    lastMeasureTime = currentMillis;
    long dist = readDistanceFiltered();
    
    Serial.printf("Filtrelenmis Mesafe: %ld cm\n", dist);

    // Mesafe uygunsa FLAŞ YANSIN (Kullanıcıya çekime hazır bildirimi)
    if (dist >= MIN_DISTANCE && dist <= MAX_DISTANCE) {
      digitalWrite(LED_PIN, HIGH); 
    } else {
      digitalWrite(LED_PIN, LOW);
    }
  }


  if (digitalRead(BUTTON_PIN) == LOW) {
    // Çekimden önce flaşı bir anlık kapatıp açmak (odaklanma simülasyonu)
    digitalWrite(LED_PIN, LOW); delay(50);
    digitalWrite(LED_PIN, HIGH);
    
    Serial.println("Fotograf cekiliyor...");
    camera_fb_t * fb = esp_camera_fb_get();
    
    if (!fb) { 
      Serial.println("Kamera Hatasi!"); 
    } else {
      String signature = calculateHMAC(fb->buf, fb->len);
      
      HTTPClient http;
      http.begin(serverUrl);
      http.setTimeout(30000); 
      http.addHeader("Content-Type", "application/octet-stream");
      http.addHeader("X-Signature", signature);

      int httpResponseCode = http.POST(fb->buf, fb->len);
      
      if (httpResponseCode > 0) {
        String response = http.getString();
        Serial.println("Sunucu Yaniti: " + response);
        
        digitalWrite(LED_PIN, LOW); delay(200);

        if(response.indexOf("GRANTED") >= 0) {
           digitalWrite(LED_PIN, HIGH); delay(2000); digitalWrite(LED_PIN, LOW);
        } else {
           for(int i=0; i<3; i++){ 
             digitalWrite(LED_PIN, HIGH); delay(150); digitalWrite(LED_PIN, LOW); delay(150); 
           }
        }
      } else {
        Serial.printf("Gonderim Hatasi: %s\n", http.errorToString(httpResponseCode).c_str());
        // Hata durumunda flaşı söndür
        digitalWrite(LED_PIN, LOW);
      }
      esp_camera_fb_return(fb);
      http.end();
    }
    
    while(digitalRead(BUTTON_PIN) == LOW) { delay(10); }
  }
  delay(10); 
}
